# /etc/profile - System-wide environment and startup configurations

export PATH=/bin:/sbin:/usr/bin:/usr/sbin
export HOME=/root
export USER=root
export LOGNAME=root

# Set colored command prompt (purple for hostname, blue for working directory)
export PS1='\[\033[01;35m\]GungnirOS\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]# '

# Aliases
alias ls='ls --color=auto'
alias ll='ls -la'
alias la='ls -A'
alias grep='grep --color=auto'
alias pacman='/usr/bin/pacman'

# Display system welcome message
if [ -f /etc/issue ]; then
  cat /etc/issue
fi
echo ""
echo "Welcome to GungnirOS!"
echo "Type 'pacman --help' to use the package manager."
echo ""
